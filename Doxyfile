# Doxyfile for clacc -- clac to C0 bytecode compiler

PROJECT_NAME           = "clacc"
PROJECT_BRIEF          = "clac to C0 bytecode compiler"
PROJECT_NUMBER         =

OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

# Input sources
INPUT                  = . lib
FILE_PATTERNS          = *.h *.c
RECURSIVE              = NO
EXCLUDE_PATTERNS       = */tools/*

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# C-specific
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# Graphs (disabled by default; set HAVE_DOT = YES if Graphviz is installed)
HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Warnings
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
